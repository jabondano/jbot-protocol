    "templates": [
      {
        "id": "proposal-followup",
        "name": "Proposal Follow-up",
        "stage": "Proposal Sent",
        "touch_number": 1,
        "subject": "Re: {{company_name}} Proposal",
        "body": "Hi {{contact_name}},\n\nFollowing up on the proposal I sent last week. Do you have any questions I can answer?\n\nBest,\n{{owner_name}}"
      },
      {
        "id": "negotiation-check-in",
        "name": "Negotiation Check-in",
        "stage": "Negotiation",
        "touch_number": 1,
        "subject": "Re: {{company_name}} - Next Steps",
        "body": "Hi {{contact_name}},\n\nJust checking in on where we stand. Are there any remaining questions or concerns I can address?\n\nBest,\n{{owner_name}}"
      }
    ]
  },
  
